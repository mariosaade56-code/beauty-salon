generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  name         String?
  email        String    @unique
  passwordHash String?
  role         Role      @default(STAFF)
  isActive     Boolean   @default(true)
  staffProfile Staff?
  sessions     Session[]
  createdAt    DateTime  @default(now())
}

enum Role {
  ADMIN
  STAFF
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique @default(cuid())
  expiresAt    DateTime
  lastActiveAt DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Staff ───────────────────────────────────────────────────────────────────

model Staff {
  id           String        @id @default(cuid())
  userId       String?       @unique
  user         User?         @relation(fields: [userId], references: [id])
  name         String
  email        String?
  phone        String?
  avatar       String?
  color        String        @default("#6366f1")
  isActive     Boolean       @default(true)
  // Helper "extra slot" for a technician: bookable anytime with no conflict
  // checks, shown grouped under its parent in the calendar.
  overbook     Boolean       @default(false)
  parentId     String?
  parent       Staff?        @relation("StaffHelpers", fields: [parentId], references: [id])
  helpers      Staff[]       @relation("StaffHelpers")
  appointments Appointment[]
  breaks       Break[]
  daysOff      DayOff[]
  createdAt    DateTime      @default(now())
}

// ─── Services ────────────────────────────────────────────────────────────────

model Service {
  id           String        @id @default(cuid())
  name         String
  nameAr       String?
  category     String
  duration     Int
  price        Float?
  description  String?
  isActive     Boolean       @default(true)
  reminderDays Int?
  appointments Appointment[]
  packages     Package[]
  createdAt    DateTime      @default(now())
}

// ─── Clients ─────────────────────────────────────────────────────────────────

model Client {
  id              String              @id @default(cuid())
  name            String
  phone           String              @unique
  email           String?
  notes           String?
  dob             DateTime?
  address         String?
  appointments    Appointment[]
  clientPackages  ClientPackage[]
  photos          ClientPhoto[]
  transactions    ClientTransaction[]
  pendingWork     PendingWork[]
  createdAt       DateTime            @default(now())
}

// Work a client still owes from a visit — e.g. booked a full body laser
// but left before the legs were done. Shown until someone marks it done.
model PendingWork {
  id            String    @id @default(cuid())
  clientId      String
  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  appointmentId String?
  fromService   String?
  description   String
  createdAt     DateTime  @default(now())
  doneAt        DateTime?
}

model ClientTransaction {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date        DateTime @default(now())
  description String
  amount      Float
  paid        Boolean  @default(true)
  reference   String?
  createdAt   DateTime @default(now())
}

// ─── Appointments ─────────────────────────────────────────────────────────────

model Appointment {
  id              String            @id @default(cuid())
  clientId        String
  client          Client            @relation(fields: [clientId], references: [id])
  staffId         String?
  staff           Staff?            @relation(fields: [staffId], references: [id])
  serviceId       String
  service         Service           @relation(fields: [serviceId], references: [id])
  startTime       DateTime
  endTime         DateTime
  status          AppointmentStatus @default(PENDING)
  source          BookingSource     @default(WEBSITE)
  notes             String?
  googleEventId     String?
  reminderSent24h   Boolean        @default(false)
  reminderSent1h    Boolean        @default(false)
  rebookReminderSent Boolean       @default(false)
  clientPackageId   String?
  clientPackage     ClientPackage? @relation(fields: [clientPackageId], references: [id])
  paymentStatus     PaymentStatus?
  amountPaid        Float?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

enum PaymentStatus {
  PAID
  PARTIAL
  UNPAID
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  NO_SHOW
  COMPLETED
}

enum BookingSource {
  WEBSITE
  WHATSAPP
  WALKIN
  MANUAL
}

// ─── Packages ────────────────────────────────────────────────────────────────

model Package {
  id             String          @id @default(cuid())
  name           String
  serviceId      String
  service        Service         @relation(fields: [serviceId], references: [id])
  sessionCount   Int
  price          Float
  validityDays   Int             @default(365)
  isActive       Boolean         @default(true)
  clientPackages ClientPackage[]
  createdAt      DateTime        @default(now())
}

model ClientPackage {
  id            String      @id @default(cuid())
  clientId      String
  client        Client      @relation(fields: [clientId], references: [id])
  packageId     String
  package       Package     @relation(fields: [packageId], references: [id])
  sessionsTotal Int
  sessionsUsed  Int         @default(0)
  purchasedAt   DateTime    @default(now())
  expiresAt     DateTime?
  notes         String?
  appointments  Appointment[]
}

// ─── Client Photos ────────────────────────────────────────────────────────────

model ClientPhoto {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  url       String
  type      String   @default("GENERAL")
  notes     String?
  takenAt   DateTime @default(now())
  createdAt DateTime @default(now())
}

// ─── Breaks & Closures ───────────────────────────────────────────────────────

model Break {
  id        String   @id @default(cuid())
  staffId   String
  staff     Staff    @relation(fields: [staffId], references: [id])
  startTime DateTime
  endTime   DateTime
  label     String?
  dayOfWeek Int?
  createdAt DateTime @default(now())
}

model DayOff {
  id       String   @id @default(cuid())
  staffId  String?
  staff    Staff?   @relation(fields: [staffId], references: [id])
  date     DateTime @db.Date
  reason   String?
  allStaff Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── Expenses ─────────────────────────────────────────────────────────────────

model Expense {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  category    String
  description String?
  amount      Float
  createdAt   DateTime @default(now())
}

// ─── Settings ─────────────────────────────────────────────────────────────────

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ─── WhatsApp session state ───────────────────────────────────────────────────

model WhatsappSession {
  id        String   @id @default(cuid())
  phone     String   @unique
  state     String   @default("idle")
  data      Json     @default("{}")
  updatedAt DateTime @updatedAt
}
